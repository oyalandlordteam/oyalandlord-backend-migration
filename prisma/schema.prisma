// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  name              String
  role              String            // 'admin' | 'tenant' | 'landlord' | 'solicitor'
  isVerified        Boolean           @default(false)
  isActive          Boolean           @default(true)
  isDeleted         Boolean           @default(false)
  deletionReason    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  properties        Property[]        @relation("LandlordProperties")
  inspections       Inspection[]      @relation("TenantInspections")
  receivedMessages  Message[]         @relation("ReceiverMessages")
  sentMessages      Message[]         @relation("SenderMessages")
  favorites         Favorite[]
  reports           PropertyReport[]  @relation("Reporter")
  notifications     Notification[]
}

model Property {
  id              String           @id @default(cuid())
  propertyCode    String           @unique
  title           String
  description     String
  location        String
  price           Float
  type            String           // 'flat' | 'house' | 'self-contain' | 'mini-flat'
  bedrooms        Int
  images          String           // JSON string array
  security        String           // JSON string array
  parking         String           // JSON string array
  outdoorSpace    String           // JSON string array
  petPolicy       String           // 'allowed' | 'not_allowed' | 'case_by_case'
  furnishing      String           // 'furnished' | 'unfurnished' | 'semi-furnished'
  breakdownItems  String           // JSON string array (BreakdownItem)
  available       Boolean          @default(true)
  isDeleted       Boolean          @default(false)
  deletionReason  String?
  landlordId      String
  landlord        User             @relation("LandlordProperties", fields: [landlordId], references: [id])
  inspections     Inspection[]
  messages        Message[]
  favorites       Favorite[]
  reports         PropertyReport[]
  rentals         Rental[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Inspection {
  id              String           @id @id @default(cuid())
  propertyId      String
  property        Property         @relation(fields: [propertyId], references: [id])
  tenantId        String
  tenant          User             @relation("TenantInspections", fields: [tenantId], references: [id])
  status          String           @default("pending") // 'pending' | 'approved' | 'rejected'
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  solicitorComments SolicitorComment[]
}

model Message {
  id          String    @id @default(cuid())
  content     String
  isRead      Boolean   @default(false)
  senderId    String
  sender      User      @relation("SenderMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User      @relation("ReceiverMessages", fields: [receiverId], references: [id])
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
  rentalId    String?
  rental      Rental?   @relation(fields: [rentalId], references: [id])
  createdAt   DateTime  @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // 'inspection' | 'rental' | 'message' | 'system'
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Rental {
  id              String    @id @default(cuid())
  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id])
  tenantId        String
  landlordId      String
  status          String    @default("active") // 'active' | 'completed' | 'cancelled'
  rentAmount      Float
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        Message[]
}

model Favorite {
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@id([userId, propertyId])
}

model PropertyReport {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
  reason      String   // 'misleading' | 'unavailable' | 'scam' | 'other'
  description String?
  status      String   @default("pending") // 'pending' | 'reviewed' | 'resolved'
  createdAt   DateTime @default(now())
}

model SystemContent {
  id        String   @id @default(cuid())
  key       String   @unique // 'faq', 'aboutUs', 'terms'
  content   String   // Stored as JSON string
  updatedAt DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SolicitorComment {
  id            String   @id @default(cuid())
  inspectionId  String
  inspection    Inspection @relation(fields: [inspectionId], references: [id])
  solicitorId   String
  comment       String
  createdAt     DateTime @default(now())
}
