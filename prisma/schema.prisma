// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model for all roles
model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  role            String           // "tenant", "landlord", "solicitor", "admin"
  isVerified      Boolean          @default(false)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?
  deletionReason  String?
  
  // Relations
  properties      Property[]       @relation("LandlordProperties")
  assignedLoans   Property[]       @relation("SolicitorProperties")
  inspections     Inspection[]     @relation("TenantInspections")
  givenInspections Inspection[]    @relation("LandlordInspections")
  rentals         RentalAgreement[] @relation("TenantRentals")
  landlordRentals RentalAgreement[] @relation("LandlordRentals")
  bids            Bid[]
  messagesSent    Message[]        @relation("SentMessages")
  messagesReceived Message[]       @relation("ReceivedMessages")
  notifications   Notification[]
  reports         PropertyReport[] @relation("Reporter")
  favorites       Favorite[]
  solicitorComments SolicitorComment[]
}

// Property listing model
model Property {
  id              String           @id @default(uuid())
  title           String
  description     String
  location        String
  price           Float
  type            String           // "apartment", "house", "villa", "studio"
  bedrooms        String           // "1", "2", "3", "4+"
  bathrooms       Int
  images          String           // JSON string of image URLs
  amenities       String           // JSON string of amenities list
  available       Boolean          @default(true)
  featured        Boolean          @default(false)
  landlordId      String
  solicitorId     String?
  propertyCode    String           @unique
  viewCount       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isDeleted       Boolean          @default(false)
  deletionReason  String?

  // Extended property details
  powerSupply     String?          // JSON string
  waterSupply     String?          // JSON string
  nearbyAmenities String?          // JSON string
  allowNegotiation Boolean         @default(false)
  
  // Relations
  landlord        User             @relation("LandlordProperties", fields: [landlordId], references: [id])
  solicitor       User?            @relation("SolicitorProperties", fields: [solicitorId], references: [id])
  inspections     Inspection[]
  rentals         RentalAgreement[]
  bids            Bid[]
  reports         PropertyReport[]
  favorites       Favorite[]
  screeningQuestions ScreeningQuestion[]

  @@index([landlordId])
  @@index([solicitorId])
}

model ScreeningQuestion {
  id          String   @id @default(uuid())
  propertyId  String
  question    String
  
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
}

// Inspection request model
model Inspection {
  id              String           @id @default(uuid())
  propertyId      String
  tenantId        String
  landlordId      String
  date            String
  time            String
  notes           String?
  status          String           @default("pending") // "pending", "approved", "rejected", "completed"
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  approvedAt      DateTime?
  rejectedAt      DateTime?
  screeningAnswers String?         // JSON string

  // Relations
  property        Property         @relation(fields: [propertyId], references: [id])
  tenant          User             @relation("TenantInspections", fields: [tenantId], references: [id])
  landlord        User             @relation("LandlordInspections", fields: [landlordId], references: [id])
  comments        SolicitorComment[]

  @@index([propertyId])
  @@index([tenantId])
  @@index([landlordId])
}

// Solicitor comments on inspections
model SolicitorComment {
  id              String    @id @default(uuid())
  inspectionId    String
  solicitorId     String
  comment         String
  createdAt       DateTime  @default(now())

  inspection      Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  solicitor       User       @relation(fields: [solicitorId], references: [id])

  @@index([inspectionId])
  @@index([solicitorId])
}

// Rental Agreement model
model RentalAgreement {
  id              String           @id @default(uuid())
  propertyId      String
  tenantId        String
  landlordId      String
  startDate       DateTime
  endDate         DateTime
  amount          Float
  status          String           @default("active") // "active", "expired", "terminated"
  receiptNumber   String           @unique
  agreementUrl    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  property        Property         @relation(fields: [propertyId], references: [id])
  tenant          User             @relation("TenantRentals", fields: [tenantId], references: [id])
  landlord        User             @relation("LandlordRentals", fields: [landlordId], references: [id])

  @@index([propertyId])
  @@index([tenantId])
  @@index([landlordId])
}

// Rent bids / negotiations
model Bid {
  id              String           @id @default(uuid())
  propertyId      String
  tenantId        String
  amount          Float
  status          String           @default("pending") // "pending", "accepted", "rejected"
  createdAt       DateTime         @default(now())

  // Relations
  property        Property         @relation(fields: [propertyId], references: [id])
  tenant          User             @relation(fields: [tenantId], references: [id])

  @@index([propertyId])
  @@index([tenantId])
}

// Messaging system
model Message {
  id              String           @id @default(uuid())
  senderId        String
  receiverId      String
  content         String
  propertyId      String?
  rentalId        String?
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())

  // Relations
  sender          User             @relation("SentMessages", fields: [senderId], references: [id])
  receiver        User             @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
}

// Notifications
model Notification {
  id              String           @id @default(uuid())
  userId          String
  title           String
  message         String
  type            String           // "info", "success", "alert", "message"
  read            Boolean          @default(false)
  link            String?
  createdAt       DateTime         @default(now())

  // Relations
  user            User             @relation(fields: [userId], references: [id])

  @@index([userId])
}

// Property Reports / Complaints
model PropertyReport {
  id              String           @id @default(uuid())
  propertyId      String
  reporterId      String
  reason          String
  description     String
  status          String           @default("pending") // "pending", "reviewed", "resolved"
  createdAt       DateTime         @default(now())

  // Relations
  property        Property         @relation(fields: [propertyId], references: [id])
  reporter        User             @relation("Reporter", fields: [reporterId], references: [id])

  @@index([propertyId])
  @@index([reporterId])
}

// User Favorites
model Favorite {
  id              String           @id @default(uuid())
  userId          String
  propertyId      String
  createdAt       DateTime         @default(now())

  // Relations
  user            User             @relation(fields: [userId], references: [id])
  property        Property         @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

// Platform Announcements
model Announcement {
  id              String           @id @default(uuid())
  title           String
  message         String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
}

// Platform settings (e.g., global fees)
model SystemSettings {
  id                  String   @id @default("singleton")
  maintenanceMode     Boolean  @default(false)
  defaultInspectionFee Float   @default(5000)
  language            String   @default("en")
  updatedAt           DateTime @updatedAt
}

// CMS Content model (FAQ, About, Terms)
model SystemContent {
  id        String   @id @default(uuid())
  key       String   @unique // e.g., 'faq', 'aboutUs', 'terms'
  content   String   // JSON string or long text
  updatedAt DateTime @updatedAt
}
